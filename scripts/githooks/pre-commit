#!/usr/bin/env bash
set -euo pipefail
cargo fmt --all -- --check
gitleaks protect --staged --redact
# Block corpus data and model weights from ever being staged. Kept in lockstep
# with .gitignore: corpus/ and weights/ dirs, model-weight formats (gguf,
# safetensors, bin), and corpus database formats (sqlite, duckdb).
if git diff --cached --name-only | grep -E '^(corpus|weights)/|\.(gguf|safetensors|bin|sqlite|duckdb)$'; then
  echo "Refusing commit: corpus data or model weights must not enter this repo." >&2
  exit 1
fi
