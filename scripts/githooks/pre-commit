#!/usr/bin/env bash
set -euo pipefail
cargo fmt --all -- --check
# Content boundary gate (leak methodology L3b): corpus-row shapes, canonical
# poison tokens, and base64/hex-encoded smuggling in the STAGED blobs —
# content-keyed, so renames, double extensions, and `git add -f` do not
# bypass it. The required CI `boundary` job re-runs the same scan server-side.
cargo run -q -p xtask -- scan-content --staged
# gitleaks locally is warn-and-skip (L3c): the required CI `secrets` job is the
# server-side backstop, so the hook stays installable on a machine without it.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact
else
  echo "warning: gitleaks not installed — relying on the CI secrets job (see BOUNDARY.md)." >&2
fi
# Block corpus data and model weights from ever being staged. Kept in lockstep
# with .gitignore: corpus/ and weights/ dirs, model-weight formats (gguf,
# safetensors, bin), corpus database formats (sqlite, duckdb), AND the private-
# corpus boundary shapes (compiled rows, authored flows, seeds, any cec-corpus path).
if git diff --cached --name-only | grep -E '^(corpus|weights)/|\.(gguf|safetensors|bin|sqlite|duckdb|jsonl|ndjson|seed|seedhex|env)$|\.flow\.ya?ml$|cec-corpus'; then
  echo "Refusing commit: corpus data, model weights, or private-corpus material must not enter this repo." >&2
  exit 1
fi
